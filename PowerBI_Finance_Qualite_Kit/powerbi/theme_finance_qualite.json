{
  "name": "Finance Qualite Data Governance",
  "dataColors": [
    "#0B1F3A",
    "#1F77B4",
    "#2CA02C",
    "#FF7F0E",
    "#D62728",
    "#9467BD",
    "#17BECF",
    "#7F7F7F",
    "#BCBD22",
    "#8C564B"
  ],
  "background": "#F7F9FC",
  "foreground": "#0B1F3A",
  "tableAccent": "#1F77B4",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#0B1F3A"
              }
            },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5EAF2"
              }
            },
            "radius": 8
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#0B1F3A"
              }
            },
            "fontSize": 22,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#64748B"
              }
            },
            "fontSize": 10
          }
        ]
      }
    }
  }
}