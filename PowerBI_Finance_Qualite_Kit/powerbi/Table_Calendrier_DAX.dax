Calendrier =
ADDCOLUMNS(
    CALENDAR(
        MIN('donnees_finance_powerbi'[date_periode]),
        MAX('donnees_finance_powerbi'[date_periode])
    ),
    "Année", YEAR([Date]),
    "Mois Num", MONTH([Date]),
    "Mois", FORMAT([Date], "MMMM"),
    "Mois Année", FORMAT([Date], "YYYY-MM"),
    "Trimestre", "T" & FORMAT([Date], "Q")
)